{
  // Extends ./tsconfig.hardening.json (vendored copy) for shared hardening flags:
  // strict, noUncheckedIndexedAccess, exactOptionalPropertyTypes,
  // noImplicitOverride, noFallthroughCasesInSwitch,
  // noPropertyAccessFromIndexSignature, forceConsistentCasingInFileNames.
  //
  // noPropertyAccessFromIndexSignature is overridden to false here because
  // process.env.X access is pervasive and this flag is style-level, not
  // security-critical. The substantive flags (strict, noUncheckedIndexedAccess,
  // exactOptionalPropertyTypes, noImplicitOverride) are all inherited.
  // TODO: remove this override once process.env accesses use bracket notation.
  "extends": ["@tsconfig/node22/tsconfig.json", "./tsconfig.hardening.json"],
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "noPropertyAccessFromIndexSignature": false
  },
  "include": ["src", "src/**/*.test.ts"],
  "exclude": ["dist", "node_modules"]
}
